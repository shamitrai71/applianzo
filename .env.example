AMAZON_ACCESS_KEY=your_access_key
AMAZON_SECRET_KEY=your_secret_key

# Replace these with your actual Amazon Associates tags per country
AMAZON_TAG_IN=yourtag-21
AMAZON_TAG_US=yourtag-20
AMAZON_TAG_UK=yourtag-21

NEON_DATABASE_URL=your_neon_connection_string

# Set this to your deployed Netlify URL to restrict CORS
# e.g. https://applianzo.netlify.app
# Leave as * only during local development
ALLOWED_ORIGIN=*
