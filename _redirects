# Netlify Redirects — Applianzo
# https://docs.netlify.com/routing/redirects/

# Root → splash (belt-and-suspenders alongside index.html)
/                           /applianzo-splash.html    200

# Clean URL aliases (so /login works in addition to /applianzo-login.html)
/splash                     /applianzo-splash.html    200
/login                      /applianzo-login.html     200
/signup                     /applianzo-login.html     200
/profile                    /applianzo-profile.html   200
/admin                      /applianzo-admin.html     200

# Catch-all 404 → redirect to main site gracefully
/*                          /applianzo.html           404
